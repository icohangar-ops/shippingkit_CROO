# ShipKit environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# --- AI console (/playground, /api/chat) ---
# Lovable AI Gateway key used to stream gemini-3-flash. Server-only secret.
LOVABLE_API_KEY=

# Shared-secret gate for POST /api/chat. The route fails closed (503) when
# this is unset, so set it to enable the AI console. Server-only secret.
SHIPKIT_API_TOKEN=

# --- E2E live mode (scripts/e2e-shipkit.ts --mode live) ---
# Only needed when running the harness against real CROO endpoints.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=croo_sk_...

# --- Public, client-readable config (must keep the VITE_ prefix) ---
# These ship to the browser. Never place secrets here.
# VITE_FOO=
